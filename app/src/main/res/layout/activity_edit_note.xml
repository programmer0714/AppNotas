<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/fondoApp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Nota"
        android:textColor="@color/black"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_gravity="center" />

    <EditText
        android:id="@+id/edtTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Título"
        android:layout_marginTop="20dp"
        android:padding="12dp"
        android:background="@drawable/card_note"
        android:textColor="@color/black"
        android:textSize="18sp" />

    <EditText
        android:id="@+id/edtContenido"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:hint="Contenido"
        android:layout_marginTop="10dp"
        android:padding="12dp"
        android:gravity="top"
        android:background="@drawable/card_note"
        android:textColor="@color/black"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnGuardarCambios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar Cambios"
        android:textColor="@color/white"
        android:background="@drawable/boton_fondo"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnEliminarNota"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Eliminar Nota"
        android:textColor="@color/white"
        android:backgroundTint="@color/colorError"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Volver Atrás"
        android:textColor="@color/white"
        android:background="@drawable/boton_fondo_sec"
        android:layout_marginTop="10dp" />

</LinearLayout>